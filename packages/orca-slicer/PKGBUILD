pkgname='orca-slicer'
pkgver=2.4.1
pkgrel=1
pkgdesc="OrcaSlicer - A small open-source slicer for 3D printers"
arch=('x86_64')
url="https://github.com/SoftFever/OrcaSlicer"
license=('AGPL-3.0-only')
depends=('glu' 'cairo' 'gtk3' 'gstreamer' 'wayland' 'webkit2gtk-4.1' 'mesa-utils' 'libmspack' 'libice' 'libsm')
provides=("${pkgname}")
conflicts=("${pkgname}")
options=(!strip !zipman !debug)

appimage="orca-slicer-${pkgver}.AppImage"
source=("${appimage}::https://github.com/SoftFever/OrcaSlicer/releases/download/v${pkgver}/OrcaSlicer_Linux_AppImage_Ubuntu2404_V${pkgver}.AppImage")
sha256sums=('7aff29a0ac6bb906f11c069eefe83459781c3364bac20ba9529eb9937a231402')

prepare() {
  chmod +x ${appimage}
  ./${appimage} --appimage-extract
}

package() {
  install -d ${pkgdir}/opt/${pkgname}/
  cp -a squashfs-root/* ${pkgdir}/opt/${pkgname}/
  rm -rf ${pkgdir}/opt/${pkgname}/{usr,com.orcaslicer.OrcaSlicer.desktop,OrcaSlicer.png}

  install -d $pkgdir/usr/bin
  ln -s /opt/${pkgname}/AppRun ${pkgdir}/usr/bin/orca-slicer

  install -Dm644 squashfs-root/com.orcaslicer.OrcaSlicer.desktop ${pkgdir}/usr/share/applications/orca-slicer.desktop
  sed -i '/^Exec=/ c\Exec=/opt/orca-slicer/AppRun %U' ${pkgdir}/usr/share/applications/orca-slicer.desktop
  sed -i '/^MimeType=/ s|$|x-scheme-handler/orcaslicer;x-scheme-handler/bambustudio;|' ${pkgdir}/usr/share/applications/orca-slicer.desktop

  install -d ${pkgdir}/usr/share/icons/
  cp -r squashfs-root/usr/share/icons/hicolor/ ${pkgdir}/usr/share/icons/

  chmod +x ${pkgdir}/opt/${pkgname}/libexec/orca-slicer-env
}

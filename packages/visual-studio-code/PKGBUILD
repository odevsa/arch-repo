pkgname=visual-studio-code
pkgver=1.124.2
pkgrel=1
pkgdesc="Visual Studio Code - Official Code editor from Microsoft"
arch=('x86_64')
url="https://code.visualstudio.com/"
license=('custom:commercial')
depends=('alsa-lib' 'gtk3' 'nss' 'libxss' 'libxtst' 'xdg-utils' 'libsecret')
optdepends=('libdbusmenu-glib: Suporte a menus globais no Desktop')
provides=('code' 'vscode' 'visual-studio-code')
conflicts=('code')
options=(!strip)

source=(
  "visual-studio-code-${pkgver}.deb::https://update.code.visualstudio.com/${pkgver}/linux-deb-x64/stable"
  "visual-studio-code.sh"
)
sha256sums=(
  'SKIP'
  'SKIP'
)

package() {
  bsdtar -xf data.tar.xz -C "${pkgdir}/"

  install -d "${pkgdir}/usr/bin"
  install -d "${pkgdir}/usr/share/licenses/${pkgname}"

  ln -s /usr/share/code/resources/app/LICENSE.rtf \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE.rtf"

  install -m755 "${srcdir}/${pkgname}.sh" "${pkgdir}/usr/bin/code"

  sed -i \
    -e 's/^\(Exec=\)[^ ]*/\1code/g' \
    "${pkgdir}"/usr/share/applications/*.desktop

  chmod u-s "${pkgdir}/usr/share/code/chrome-sandbox"
}
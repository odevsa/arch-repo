#!/usr/bin/env bash
set -euo pipefail
source "packages/helpers"

# Get latest version
URL="https://update.code.visualstudio.com/api/update/linux-x64/stable/latest"
RESPONSE=$(curl -sSL "${URL}")
LATEST_VERSION=$(printf '%s' "$RESPONSE" | sed -n 's/.*"productVersion"[[:space:]]*:[[:space:]]*"\([^\"]*\)".*/\1/p; t; s/.*"version"[[:space:]]*:[[:space:]]*"\([^\"]*\)".*/\1/p; t; s/.*"name"[[:space:]]*:[[:space:]]*"\([^\"]*\)".*/\1/p')

update_version "$LATEST_VERSION"
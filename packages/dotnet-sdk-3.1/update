#!/usr/bin/env bash
set -euo pipefail
source "packages/helpers"

# Get latest version
URL="https://dotnetcli.blob.core.windows.net/dotnet/release-metadata/3.1/releases.json"
RESPONSE=$(curl -sSL "${URL}")
LATEST_VERSION=$(printf '%s' "$RESPONSE" | awk '
  BEGIN{in_sdk=0; max=""; maxlen=0}
  /"sdk"[[:space:]]*:/ { in_sdk=1; next }
  {
    if(in_sdk){
      if($0 ~ /\}/){ in_sdk=0; next }
      if(match($0, /"version"[[:space:]]*:[[:space:]]*"([^"]+)"/, m)){
        v = m[1]
        n = split(v, av, /\./)
        if(max==""){
          max = v
          maxlen = n
          for(i=1;i<=n;i++) maxn[i]=av[i]+0
        } else {
          split(max, bv, /\./)
          mlen = (n>maxlen? n:maxlen)
          replaced=0
          for(i=1;i<=mlen;i++){
            ai = (i<=n? av[i]+0:0)
            bi = (i<=maxlen? maxn[i]+0:0)
            if(ai>bi){ max=v; maxlen=n; for(j=1;j<=n;j++) maxn[j]=av[j]+0; replaced=1; break }
            else if(ai<bi){ replaced=1; break }
          }
          if(!replaced && n>maxlen){ max=v; maxlen=n; for(j=1;j<=n;j++) maxn[j]=av[j]+0 }
        }
      }
    }
  }
  END{ print max }
')

update_version "$LATEST_VERSION"

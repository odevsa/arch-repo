pkgname='gamepad'
pkgver=0.1.0
pkgrel=1
pkgdesc="Gamepad - A small open-source gamepad tester"
arch=('x86_64')
url="https://github.com/odevsa/gamepad"
license=('none')
provides=("${pkgname}")
conflicts=("${pkgname}")
options=(!strip !zipman !debug)

source=("${pkgname}-${pkgver}.zip::https://github.com/odevsa/gamepad/releases/download/${pkgver}/gamepad-${pkgver}-x86_64.zip")
sha256sums=('SKIP')

package() {
  install -Dm755 "${pkgname}" "${pkgdir}/usr/bin/${pkgname}"

  install -Dm755 "${pkgname}.png" "${pkgdir}/usr/share/pixmaps/${pkgname}.png"

  install -Dm755 "${pkgname}.desktop" "${pkgdir}/usr/share/applications/${pkgname}.desktop"
}

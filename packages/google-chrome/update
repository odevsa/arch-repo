#!/usr/bin/env bash
set -euo pipefail
source "packages/helpers"

# Get latest version
URL="https://dl.google.com/linux/chrome/deb/dists/stable/main/binary-amd64/Packages.gz"
RESPONSE=$(curl -sSL "${URL}" | gunzip -c 2>/dev/null || true)
LATEST_VERSION=$(printf '%s' "$RESPONSE" | awk '/^Package: google-chrome-stable/{p=1} p && /^Version:/{print $2; exit}' | sed 's/-[^-]*$//')

update_version "$LATEST_VERSION"
